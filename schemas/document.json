{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "document",
  "title": "Document",
  "description": "Normalized output for downstream chunking/embedding",
  "type": "object",
  "required": [
    "doc_id",
    "meta",
    "sections"
  ],
  "properties": {
    "doc_id": {
      "type": "string",
      "format": "uuid"
    },
    "meta": {
      "type": "object",
      "required": [
        "title",
        "source",
        "ingested_at"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "source": {
          "type": "object",
          "required": [
            "type",
            "path"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "html",
                "pdf",
                "epub"
              ]
            },
            "path": {
              "type": "string"
            },
            "url": {
              "type": [
                "string",
                "null"
              ]
            },
            "rawdoc_id": {
              "type": "string"
            }
          }
        },
        "authors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "published_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "updated_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "ingested_at": {
          "type": "string",
          "format": "date-time"
        },
        "language": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "parser_version": {
          "type": "string"
        }
      }
    },
    "references": {
      "type": "array",
      "description": "Bibliography entries resolved from source (e.g. ar5iv HTML); cite ref_id matches ref_id here",
      "items": {
        "type": "object",
        "required": [
          "ref_id",
          "text"
        ],
        "properties": {
          "ref_id": {
            "type": "string",
            "description": "Stable id, e.g. bib.bib2 from HTML anchor"
          },
          "label": {
            "type": "string",
            "description": "Human label from bibliography, e.g. [2]"
          },
          "text": {
            "type": "string",
            "description": "Full entry as plain text"
          },
          "blocks": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "LaTeXML ltx_bibblock segments when present"
          }
        },
        "additionalProperties": false
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "section_id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "heading",
              "paragraph",
              "list",
              "table",
              "code",
              "figure"
            ]
          },
          "level": {
            "type": "integer",
            "minimum": 1,
            "maximum": 6
          },
          "content": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/listItem"
            }
          },
          "rows": {
            "type": "array"
          },
          "assets": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "asset_id": {
                  "type": "string"
                },
                "path": {
                  "type": "string"
                },
                "caption": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              }
            }
          },
          "annotations": {
            "type": "object"
          }
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "listItem": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "text": {
              "type": "string"
            },
            "items": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/listItem"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "description": "LaTeX math segment (from ar5iv / LaTeXML)",
          "properties": {
            "math": {
              "type": "string"
            },
            "display": {
              "type": "boolean"
            }
          },
          "required": [
            "math"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "description": "Bibliography citation (LaTeXML cite); omitted from Markdown export",
          "properties": {
            "cite": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "ref_id": {
                    "type": "string",
                    "description": "In-document anchor id, e.g. bib.bib35"
                  },
                  "label": {
                    "type": "string",
                    "description": "Numeric or textual label shown in the PDF-style cite"
                  }
                },
                "required": [
                  "ref_id"
                ]
              }
            }
          },
          "required": [
            "cite"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "description": "Table embedded in a paragraph flow",
          "properties": {
            "table": {
              "type": "object",
              "required": [
                "rows"
              ],
              "properties": {
                "rows": {
                  "type": "array"
                }
              },
              "additionalProperties": false
            }
          },
          "required": [
            "table"
          ],
          "additionalProperties": false
        }
      ]
    }
  }
}